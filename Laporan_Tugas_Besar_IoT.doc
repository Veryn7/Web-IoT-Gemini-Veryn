<h1>5) Estimasi Lama Pengerjaan (Timeline)</h1>
<p>Proyek selesai dalam total rentang waktu <strong>4 Minggu (1 Bulan)</strong> secara terkompresi:</p>
<ol>
    <li><strong>Minggu 1:</strong> Analisis fungsional parameter, pendaftaran token Telegram Bot API, dan pengadaan seluruh modul mikrokontroler.</li>
    <li><strong>Minggu 2:</strong> Desain diagram skematik, pembuatan database NoSQL di Cloud Firebase RTDB, serta perakitan fisik jumper breadboard.</li>
    <li><strong>Minggu 3:</strong> Penulisan program C++ ESP32 di Arduino IDE, penulisan script sinkronisasi 2-arah Firebase, dan perancangan frontend dashboard.</li>
    <li><strong>Minggu 4:</strong> Pengujian integrasi secara menyeluruh, perbaikan bug latensi jaringan, kompilasi laporan, serta penyerahan sistem.</li>
</ol>

<h1>6) Source Code Arduino IDE (C++)</h1>
<p>Berikut program fungsional lengkap yang telah memanfaatkan pustaka <code>Firebase_ESP_Client</code> secara efisien:</p>

<pre>
#include &lt;WiFi.h&gt;
#include &lt;WiFiClientSecure.h&gt;
#include &lt;UniversalTelegramBot.h&gt;
#include &lt;ArduinoJson.h&gt;
#include "DHT.h"
#include &lt;Firebase_ESP_Client.h&gt;

#include &lt;addons/TokenHelper.h&gt;
#include &lt;addons/RTDBHelper.h&gt;

#define WIFI_SSID "Kost_Damai_WiFi"
#define WIFI_PASSWORD "kopi_hitam_pahit_123"
#define BOT_TOKEN "7394850285:AAFlk_vE-Y88ILLY2859385qk_test"
#define CHAT_ID "548301290"

#define FIREBASE_DATABASE_URL "https://smart-home-io4-default-rtdb.firebaseio.com"
#define FIREBASE_AUTH "AIzaSyA38X_d7948271049285038102985390"

#define DHT_PIN 4
#define DHT_TYPE DHT22

#define RELAY_1 16
#define RELAY_2 17
#define RELAY_3 18
#define RELAY_4 19

#define RELAY_ON LOW
#define RELAY_OFF HIGH

DHT dht(DHT_PIN, DHT_TYPE);
WiFiClientSecure client;
UniversalTelegramBot bot(BOT_TOKEN, client);

FirebaseData fbdo;
FirebaseAuth auth;
FirebaseConfig config;

unsigned long lastTimeBotRan = 0;
const unsigned long BOT_MTBS = 1000;
unsigned long lastTimeSensorRan = 0;
const unsigned long SENSOR_MTBS = 5000;

bool relay1_status = false;
bool relay2_status = false;
bool relay3_status = false;
bool relay4_status = false;

float current_temp = 27.5;
float current_hum = 60.0;

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_1, OUTPUT);
  pinMode(RELAY_2, OUTPUT);
  pinMode(RELAY_3, OUTPUT);
  pinMode(RELAY_4, OUTPUT);

  digitalWrite(RELAY_1, RELAY_OFF);
  digitalWrite(RELAY_2, RELAY_OFF);
  digitalWrite(RELAY_3, RELAY_OFF);
  digitalWrite(RELAY_4, RELAY_OFF);

  dht.begin();
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  client.setInsecure();

  config.database_url = FIREBASE_DATABASE_URL;
  config.signer.tokens.legacy_token = FIREBASE_AUTH;
  Firebase.begin(&amp;config, &amp;auth);
  Firebase.reconnectWiFi(true);

  bot.sendMessage(CHAT_ID, "🚀 Sistem Smart Home ESP32 Online!", "");
}

void loop() {
  if (millis() &gt; lastTimeBotRan + BOT_MTBS) {
    int numNewMessages = bot.getUpdates(bot.last_message_received + 1);
    while (numNewMessages) {
      handleNewMessages(numNewMessages);
      numNewMessages = bot.getUpdates(bot.last_message_received + 1);
    }
    lastTimeBotRan = millis();
  }

  if (millis() &gt; lastTimeSensorRan + SENSOR_MTBS) {
    float t = dht.readTemperature();
    float h = dht.readHumidity();
    if (!isnan(t) && !isnan(h)) {
      current_temp = t;
      current_hum = h;
    }
    syncWithCloud();
    lastTimeSensorRan = millis();
  }
}
</pre>

